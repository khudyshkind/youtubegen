# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (Claude) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── OpenAI (Whisper + GPT Image) ───────────────────────────
OPENAI_API_KEY=

# ─── Google AI Studio (Gemini Image for thumbnail Mode B) ────
# Get key: https://ai.google.dev/ → Get API key (no billing required for testing)
GEMINI_API_KEY=
# Model for image generation (verify exact ID in AI Studio → Model playground)
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ─── Thumbnail AI text engine ────────────────────────────────
# Controls which engine renders text INSIDE the image for Mode B thumbnails
# Options: gpt (GPT Image 2, handles Cyrillic) | gemini | flux (Flux, poor Cyrillic)
THUMBNAIL_AI_TEXT_ENGINE=gpt

# ─── ElevenLabs (TTS) ───────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── fal.ai (Flux image generation) ─────────────────────────
FAL_KEY=
FAL_CONCURRENCY_LIMIT=40
# Max parallel GPT image requests per scene-images batch (default: 3)
GPT_BATCH_SIZE=3

# ─── Paddle ─────────────────────────────────────────────────
PADDLE_API_KEY=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
# Set to 'true' to use Paddle Sandbox (for testing before account approval)
PADDLE_SANDBOX=false

# Paddle Price IDs (create in Paddle dashboard → Catalog → Prices)
PADDLE_PRICE_BASIC=pri_
PADDLE_PRICE_STARTER=pri_
PADDLE_PRICE_PRO=pri_
PADDLE_PRICE_AGENCY=pri_
# One-time topup price IDs (Product type: Standard, Billing: One-time)
PADDLE_PRICE_TOPUP_500=pri_
PADDLE_PRICE_TOPUP_2000=pri_
PADDLE_PRICE_TOPUP_5000=pri_

# ─── Railway video server ────────────────────────────────────
RAILWAY_VIDEO_SERVER_URL=https://your-app.railway.app
RAILWAY_API_SECRET=change-me-to-a-random-secret

# ─── Very Good FFmpeg (FFmpeg-as-a-Service, eliminates local FFmpeg OOM) ────
# Получить ключ: https://verygoodffmpeg.com → Dashboard → API Keys
VGF_API_KEY=

# ─── Backblaze B2 (video storage, set in Railway env) ───────
# Cloudflare R2 was replaced — R2 blocks TLS from Railway IPs at WAF level.
# Create bucket at backblaze.com → Buckets → Create a Bucket (Public)
# Create app key: Account → App Keys → Add a New Application Key (S3-compatible)
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_BUCKET=youtubegen-videos
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_REGION=us-east-005
# Separate key scoped to backup bucket only (set in Railway env for video-server)
B2_BACKUP_KEY_ID=
B2_BACKUP_APPLICATION_KEY=
# Секрет для Vercel Webhook (generate: openssl rand -hex 16)
VERCEL_WEBHOOK_SECRET=

# ─── APIHOST.RU (Russian TTS) ───────────────────────────────
# Получить ключ: https://apihost.ru → Профиль → API Key
APIHOST_API_KEY=

# ─── SecretVoicer (Russian XTTS + ElevenLabs proxy) ─────────
# Получить ключ: https://secretvoicer.com → Personal → API Key
# BASE_URL: https://secret-voicer.ru/api/v1
SECRETVOICER_API_KEY=

# ─── Voicer (Premium TTS, ElevenLabs wrapper) ───────────────
# Получить ключ: https://voicer.mat3u.com → API → Keys
# BASE_URL: https://voicer.mat3u.com/api/v1
VOICER_API_KEY=

# ─── YouTube Data API v3 ─────────────────────────────────────
# Получить ключ: console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=

# ─── Google Cloud TTS ────────────────────────────────────────
# 1. console.cloud.google.com → APIs & Services → Enable Cloud Text-to-Speech API
# 2. Credentials → Create API Key
GOOGLE_TTS_API_KEY=

# ─── Resend (email) ──────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@youtubegen.vercel.app

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOT_USERNAME=youtubegenai_bot

# ─── Vercel (для /admin/services мониторинга) ────────────────
# Создать: https://vercel.com/account/tokens
VERCEL_TOKEN=


# ─── Russia payment (set in Railway AND Vercel env) ─────────────────────────
CARD_NUMBER=0000 0000 0000 0000
CARD_HOLDER=IVAN IVANOV
USDT_TRC20=TW6Z6iZECebHe764YCKAsv5MfVFG6G947L
USDT_ERC20=0x0f8d57d74367c4379b809399b1205f587f46104a
APP_URL=https://youtubegen.vercel.app

# ─── Sentry (error monitoring) ──────────────────────────────
# Get DSN: sentry.io → Settings → Projects → youtubegen-nextjs → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Auth token for source map uploads (needed for readable stack traces in Sentry)
# Get token: sentry.io → Settings → Auth Tokens → Create Internal Integration (scope: project:releases)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=youtubegen
SENTRY_PROJECT=youtubegen-nextjs
# Webhook secret for Sentry → Telegram alerts
# Copy "Client Secret" from Sentry → Settings → Developer Settings → Internal Integrations → Telegram Alerts
SENTRY_WEBHOOK_SECRET=

# ─── Telegram Bot (also set in Railway for video-server) ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=